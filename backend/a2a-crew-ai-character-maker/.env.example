OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_TEMPERATURE=0.6
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_VISION_MAX_TOKENS=500

REPLICATE_API_TOKEN=your_replicate_api_token
REPLICATE_MODEL=prunaai/p-image
REPLICATE_OUTPUT_COUNT=1
REPLICATE_ASPECT_RATIO=3:4

A2A_PUBLIC_BASE_URL=http://127.0.0.1:8000
A2A_RPC_PATH=/a2a
A2A_AGENT_NAME=Dream CrewAI Character Agent
A2A_AGENT_VERSION=0.1.0

CREWAI_VERBOSE=true
