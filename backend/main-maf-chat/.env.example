# Runtime
APP_ENV=dev
APP_DEBUG=true
PORT=8010

# Agent provider: openai (local dev) or azure (deployment target)
AGENT_PROVIDER=openai

# OpenAI path (recommended for local testing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI path (required when AGENT_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=preview
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Exa MCP web search (search mode)
EXA_API_KEY=
EXA_MCP_ENABLED=true
EXA_MCP_BASE_URL=https://mcp.exa.ai/mcp
EXA_MCP_TOOLS=web_search_exa
EXA_MCP_REQUIRED_IN_SEARCH=true
EXA_MCP_TIMEOUT_SECONDS=20
EXA_SEARCH_TOP_K=6

# Azure AI Search RAG
AZURE_SEARCH_SERVICE_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_USE_MANAGED_IDENTITY=false
AZURE_SEARCH_INDEX_NAME=
AZURE_SEARCH_KNOWLEDGE_BASE_NAME=
AZURE_SEARCH_MCP_ENABLED=true
AZURE_SEARCH_FALLBACK_ENABLED=true
AZURE_SEARCH_API_VERSION=2025-09-01
AZURE_SEARCH_MCP_API_VERSION=2025-11-01-preview
AZURE_SEARCH_SEMANTIC_CONFIGURATION=
AZURE_SEARCH_TOP_K=6
AZURE_SEARCH_VECTOR_K=20
AZURE_SEARCH_TIMEOUT_SECONDS=30
AZURE_SEARCH_MCP_TIMEOUT_SECONDS=30
AZURE_SEARCH_SELECT_FIELDS_RAW=
AZURE_SEARCH_CONTENT_FIELDS_RAW=content,chunk,chunk_text,text
AZURE_SEARCH_TITLE_FIELDS_RAW=title,document_title,source_title,name
AZURE_SEARCH_URL_FIELDS_RAW=url,source_url,document_url,source,uri
AZURE_SEARCH_VECTOR_FIELDS_RAW=

# Azure AI Search study-mode upload + retrieval
AZURE_SEARCH_STUDY_ENABLED=true
AZURE_SEARCH_STUDY_INDEX_NAME=
AZURE_SEARCH_STUDY_SESSION_FIELD=study_session_id
AZURE_SEARCH_STUDY_ID_FIELD=id
AZURE_SEARCH_STUDY_CONTENT_FIELD=content
AZURE_SEARCH_STUDY_TITLE_FIELD=title
AZURE_SEARCH_STUDY_URL_FIELD=url
AZURE_SEARCH_STUDY_FILENAME_FIELD=study_file_name
AZURE_SEARCH_STUDY_CHUNK_INDEX_FIELD=chunk_index
AZURE_SEARCH_STUDY_UPLOADED_AT_FIELD=uploaded_at
AZURE_SEARCH_STUDY_CHUNK_SIZE_CHARS=1400
AZURE_SEARCH_STUDY_CHUNK_OVERLAP_CHARS=200
AZURE_SEARCH_STUDY_MAX_FILE_BYTES=20000000

# Azure AI Content Safety
AZURE_CONTENT_SAFETY_ENABLED=false
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_API_KEY=
AZURE_CONTENT_SAFETY_API_VERSION=2024-09-01
AZURE_CONTENT_SAFETY_BLOCK_SEVERITY=4
AZURE_CONTENT_SAFETY_TIMEOUT_SECONDS=10
AZURE_CONTENT_SAFETY_FAIL_OPEN=true

# Existing A2A CrewAI character backend URL (deployed)
A2A_BACKEND_BASE_URL=https://dream-character-a2a.greenplant-2d9bb135.eastus.azurecontainerapps.io
A2A_RPC_PATH=/a2a
A2A_USE_PROTOCOL=true
A2A_CREATE_PATH=/api/v1/characters/create
A2A_REGENERATE_PATH=/api/v1/characters/regenerate-image
A2A_STORY_BACKEND_BASE_URL=http://127.0.0.1:8020
A2A_STORY_RPC_PATH=/a2a
A2A_STORY_USE_PROTOCOL=true
A2A_STORY_CREATE_PATH=/api/v1/stories/create
A2A_QUIZ_BACKEND_BASE_URL=http://127.0.0.1:8030
A2A_QUIZ_RPC_PATH=/a2a
A2A_QUIZ_USE_PROTOCOL=true
A2A_QUIZ_CREATE_PATH=/api/v1/quizzes/create
A2A_TIMEOUT_SECONDS=240
