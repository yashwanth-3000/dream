# Runtime
APP_ENV=dev
APP_DEBUG=true

# Agent provider: openai (local) or azure
AGENT_PROVIDER=openai

# OpenAI (required for MAF + vision)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.5

# Azure OpenAI (required only when AGENT_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=preview

# Vision
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_VISION_MAX_TOKENS=500

# Replicate
REPLICATE_API_TOKEN=
REPLICATE_MODEL=openai/gpt-image-1.5
REPLICATE_OUTPUT_COUNT=1
REPLICATE_ASPECT_RATIO=2:3

# Existing character backend (called from this service)
CHARACTER_BACKEND_BASE_URL=http://127.0.0.1:8000
CHARACTER_BACKEND_RPC_PATH=/a2a
CHARACTER_BACKEND_USE_PROTOCOL=true
CHARACTER_BACKEND_CREATE_PATH=/api/v1/characters/create
CHARACTER_BACKEND_TIMEOUT_SECONDS=240

# A2A card/rpc for this service
A2A_PUBLIC_BASE_URL=http://127.0.0.1:8020
A2A_RPC_PATH=/a2a
A2A_AGENT_NAME=Dream MAF Story Book Agent
A2A_AGENT_VERSION=0.1.0

REPLICATE_QUALITY=medium
REPLICATE_BACKGROUND=auto
REPLICATE_MODERATION=auto
REPLICATE_OUTPUT_FORMAT=webp
REPLICATE_INPUT_FIDELITY=high
REPLICATE_OUTPUT_COMPRESSION=90
